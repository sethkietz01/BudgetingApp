@model BudgetingApp.Models.UserModel

@{
    ViewData["Title"] = "Settings";
}

<div class="settings-messages">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success" role="alert">
            @TempData["SuccessMessage"]
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger" role="alert">
            @TempData["ErrorMessage"]
        </div>
    }
</div>

<div class="settings-group">
    <h1>Account</h1>
    

    <div class="change-password-group">

        <h4 class="settings-header">Change Password</h4>

        @if (ViewBag.ErrorMessage != null)
        {
            <div class="alert alert-danger" role="alert">
                @ViewBag.ErrorMessage
            </div>
        }

        @if (ViewBag.SuccessMessage != null)
        {
            <div class="alert alert-success" role="alert">
                @ViewBag.SuccessMessage
            </div>
        }
        <form id="change-password-form" method="post" asp-controller="Home" asp-action="ChangePassword">
            <div class="change-password-inputs">
                <label asp-for="Password">Current Password</label>
                <input asp-for="Password" id="current-password-input" />
                <span asp-validation-for="Password" class="text-danger"></span>

                <label for="new-password-input">New Password</label>
                <input id="new-password-input" type="password" name="newPassword" required />

                <label for="confirm-password-input">Confirm Password</label>
                <input id="confirm-new-password-input" type="password" name="confirmPassword" required />
            </div>

            <button class="button" type="submit">Change Password</button>
        </form>

    </div>
    <div class="logout-container">
        <form method="post" asp-controller="Home" asp-action="Logout">
            <button class="button" type="submit">Logout</button>
        </form>
    </div>

    <div class="delete-buttons-container">
        <button id="modal-button" class="btn btn-danger btn-sm">Delete Data</button>
        <button id="delete-account-modal-button" class="btn btn-danger btn-sm">Delete Account</button>
    </div>
    <div class="theme-switch-container">
        <span>Light</span>
        <label class="switch">
            <input type="checkbox" id="checkbox">
            <span class="slider"></span>
        </label>
        <span>Dark</span>
    </div>
</div>

<div id="modal" class="modal">
    <div class="modal-content">
        <span class="close" id="closeX">&times;</span>
        <p class="modal-text">Are you sure you wish to delete all of your data?</p>
        <div class="modal-buttons-container">
            <button class="button" id="close-button">Close</button>
            <form method="post" asp-controller="Home" asp-action="DeleteData" style="display:inline;">
                <button type="submit" class="btn btn-danger btn-sm">Delete</button>
            </form>
        </div>
    </div>
</div>

<div id="delete-account-modal" class="modal">
    <div class="modal-content">
        <span class="close" id="closeX">&times;</span>
        <p class="modal-text">Are you sure you wish to delete your account?</p>
        <div class="modal-buttons-container">
            <button class="button" id="close-button">Close</button>
            <form method="post" asp-controller="Home" asp-action="DeleteAccount" style="display:inline;">
                <button type="submit" class="btn btn-danger btn-sm">Delete</button>
            </form>
        </div>
    </div>
</div>
<div class="mfa-settings-group" style="margin-top: 20px; border-top: 1px solid #ccc; padding-top: 20px;">
    <h4 class="settings-header">Two-Factor Authentication (MFA)</h4>
    @if (Model.MfaEnabled == true)
    {
        <div class="alert alert-info">
            <p>MFA is currently <strong>Enabled</strong>.</p>
            <button type="button" id="disable-mfa-modal-button" class="btn btn-outline-danger btn-sm">Disable MFA</button>
        </div>
    }
    else
    {
        <p>Enhance your account security by requiring a 6-digit code from an authenticator app.</p>
        <a asp-controller="Auth" asp-action="SetupMfa" class="btn btn-primary">Set Up MFA</a>
    }
</div>

<div id="disable-mfa-modal" class="modal">
    <div class="modal-content">
        <span class="close" onclick="closeMfaModal()">&times;</span>
        <p class="modal-text">Are you sure you want to disable MFA? Your account will be less secure.</p>
        <div class="modal-buttons-container">
            <button class="button" onclick="closeMfaModal()">Cancel</button>
            <form method="post" asp-controller="Auth" asp-action="DisableMfa" style="display:inline;">
                <button type="submit" class="btn btn-danger btn-sm">Confirm Disable</button>
            </form>
        </div>
    </div>
</div>


<script>
    document.addEventListener("DOMContentLoaded", function() {
    const disableMfaModal = document.getElementById("disable-mfa-modal");
    const openMfaBtn = document.getElementById("disable-mfa-modal-button");

    if (openMfaBtn) {
        openMfaBtn.addEventListener("click", () => {
            disableMfaModal.style.display = "block";
        });
    }

    window.closeMfaModal = function() {
        disableMfaModal.style.display = "none";
    };


        const modal = document.getElementById("modal");
        const deletAccountModal = document.getElementById("delete-account-modal");
        const openBtn = document.getElementById("modal-button");
        const openDeleteAccountBtn = document.getElementById("delete-account-modal-button");
        const closeButton = document.getElementById("close-button");
        const closeX = document.getElementById("closeX");

        const closeModal = () => {
            if (modal.style.display == "block") {
                modal.style.display = "none";
            }
            else {
                deletAccountModal.style.display = "none";
            }
        };

        if (openBtn) {
            openBtn.addEventListener("click", () => {
                modal.style.display = "block";
            });
        }

        if (openDeleteAccountBtn) {
            openDeleteAccountBtn.addEventListener("click", () => {
                deletAccountModal.style.display = "block";
            });
        }

        if (closeButton) closeButton.addEventListener("click", closeModal);
        if (closeX) closeX.addEventListener("click", closeModal);

        window.addEventListener("click", (event) => {
            if (event.target === modal) closeModal();
        });

        const themeCheckbox = document.getElementById('checkbox');
        const currentTheme = localStorage.getItem('theme');
        const htmlElement = document.documentElement; 

        if (currentTheme) {
            htmlElement.setAttribute('data-theme', currentTheme);

            if (currentTheme === 'dark' && themeCheckbox) {
                themeCheckbox.checked = true;
            }
        }

        if (themeCheckbox) {
            themeCheckbox.addEventListener('change', function() {
                if (this.checked) {
                    htmlElement.setAttribute('data-theme', 'dark');
                    localStorage.setItem('theme', 'dark');
                } else {
                    htmlElement.setAttribute('data-theme', 'light');
                    localStorage.setItem('theme', 'light');
                }
            });
        }
    });
</script>